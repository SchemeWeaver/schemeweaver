{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemeweaver.dev/schemas/dir.schema.json",
  "title": "Diagram Intermediate Representation (DIR)",
  "description": "Structured JSON representation of a diagram, generated by Claude and rendered deterministically to semantic SVG.",
  "type": "object",
  "required": ["version", "meta", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "DIR schema version",
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$"
    },
    "meta":   { "$ref": "#/definitions/DiagramMeta" },
    "nodes":  { "type": "array", "items": { "$ref": "#/definitions/DiagramNode" } },
    "edges":  { "type": "array", "items": { "$ref": "#/definitions/DiagramEdge" } },
    "groups": { "type": "array", "items": { "$ref": "#/definitions/DiagramGroup" }, "default": [] }
  },
  "definitions": {
    "DiagramType": {
      "type": "string",
      "enum": ["architecture", "flowchart", "erd", "sequence", "generic"]
    },
    "NodeType": {
      "type": "string",
      "description": "Vendor-agnostic semantic category. Determines shape. Use vendor + technology for branding.",
      "enum": [
        "generic",
        "user",
        "service",
        "api",
        "gateway",
        "database",
        "document-store",
        "cache",
        "queue",
        "stream",
        "file-store",
        "search",
        "cdn",
        "auth",
        "monitor"
      ]
    },
    "Vendor": {
      "type": "string",
      "description": "Cloud or platform vendor. Drives icon branding and stroke color.",
      "enum": ["aws", "azure", "gcp", "cloudflare", "vercel", "hashicorp"]
    },
    "EdgeStyle":     { "type": "string", "enum": ["solid", "dashed", "dotted"] },
    "EdgeDirection": { "type": "string", "enum": ["forward", "backward", "bidirectional"] },
    "DiagramMeta": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title":        { "type": "string", "minLength": 1 },
        "description":  { "type": "string" },
        "diagram_type": { "$ref": "#/definitions/DiagramType", "default": "generic" },
        "tags":         { "type": "array", "items": { "type": "string" }, "default": [] },
        "author":       { "type": "string", "default": "schemeweaver" },
        "version":      { "type": "string", "default": "1.0" }
      }
    },
    "DiagramNode": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$" },
        "label":       { "type": "string", "minLength": 1 },
        "node_type":   { "$ref": "#/definitions/NodeType", "default": "generic" },
        "vendor":      {
          "oneOf": [{ "$ref": "#/definitions/Vendor" }, { "type": "null" }],
          "description": "Optional vendor for brand-specific rendering (AWS, Azure, GCP, etc.)",
          "default": null
        },
        "technology":  {
          "type": ["string", "null"],
          "description": "Optional specific technology or service (e.g. 'rds', 'fastapi', 'redis', 'kafka')",
          "default": null
        },
        "description": { "type": "string" },
        "metadata":    { "type": "object", "additionalProperties": true },
        "children":    { "type": "array", "items": { "$ref": "#/definitions/DiagramNode" }, "default": [] },
        "x":           { "type": "number" },
        "y":           { "type": "number" }
      }
    },
    "DiagramEdge": {
      "type": "object",
      "required": ["id", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$" },
        "from":      { "type": "string" },
        "to":        { "type": "string" },
        "label":     { "type": "string" },
        "style":     { "$ref": "#/definitions/EdgeStyle",     "default": "solid" },
        "direction": { "$ref": "#/definitions/EdgeDirection", "default": "forward" }
      }
    },
    "DiagramGroup": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$" },
        "label":    { "type": "string", "minLength": 1 },
        "contains": { "type": "array", "items": { "type": "string" }, "default": [] },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
