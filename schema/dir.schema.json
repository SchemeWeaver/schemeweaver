{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemeweaver.dev/schemas/dir.schema.json",
  "title": "Diagram Intermediate Representation (DIR)",
  "description": "Structured JSON representation of a diagram, generated by Claude and rendered deterministically to semantic SVG.",
  "type": "object",
  "required": ["version", "meta", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "DIR schema version",
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$"
    },
    "meta": {
      "$ref": "#/definitions/DiagramMeta"
    },
    "complexity_levels": {
      "type": "array",
      "description": "Ordered list of complexity levels present in this diagram (low → high)",
      "items": { "$ref": "#/definitions/ComplexityLevel" },
      "default": ["low", "medium", "high"]
    },
    "nodes": {
      "type": "array",
      "description": "All top-level diagram nodes",
      "items": { "$ref": "#/definitions/DiagramNode" }
    },
    "edges": {
      "type": "array",
      "description": "All connections between nodes",
      "items": { "$ref": "#/definitions/DiagramEdge" }
    },
    "groups": {
      "type": "array",
      "description": "Logical groupings of nodes (VPCs, regions, teams, domains)",
      "items": { "$ref": "#/definitions/DiagramGroup" },
      "default": []
    }
  },
  "definitions": {
    "ComplexityLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Complexity level: low = always visible, medium = supporting detail, high = fine-grained implementation detail"
    },
    "DiagramType": {
      "type": "string",
      "enum": ["architecture", "flowchart", "erd", "sequence", "generic"],
      "description": "The type/style of diagram"
    },
    "NodeType": {
      "type": "string",
      "enum": [
        "generic",
        "service",
        "database",
        "queue",
        "storage",
        "gateway",
        "user",
        "aws.lambda",
        "aws.s3",
        "aws.rds",
        "aws.ec2",
        "aws.elasticache",
        "aws.api_gateway"
      ],
      "description": "The semantic type of the node, used for visual styling"
    },
    "EdgeStyle": {
      "type": "string",
      "enum": ["solid", "dashed", "dotted"],
      "description": "Visual style of the edge line"
    },
    "EdgeDirection": {
      "type": "string",
      "enum": ["forward", "backward", "bidirectional"],
      "description": "Direction of the edge arrow(s)"
    },
    "DiagramMeta": {
      "type": "object",
      "description": "Metadata about the diagram",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable diagram title",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Longer description of what the diagram represents"
        },
        "diagram_type": {
          "$ref": "#/definitions/DiagramType",
          "default": "generic"
        },
        "author": {
          "type": "string",
          "description": "Author or generator of this DIR",
          "default": "schemeweaver"
        },
        "version": {
          "type": "string",
          "description": "Version of this specific diagram",
          "default": "1.0"
        }
      }
    },
    "DiagramNode": {
      "type": "object",
      "description": "A single node in the diagram",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique semantic ID in kebab-case (e.g. 'api-gateway', not 'node-1')",
          "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label displayed on the node",
          "minLength": 1
        },
        "node_type": {
          "$ref": "#/definitions/NodeType",
          "default": "generic"
        },
        "complexity": {
          "$ref": "#/definitions/ComplexityLevel",
          "default": "low"
        },
        "description": {
          "type": "string",
          "description": "What this component does — used for aria-label and tooltips"
        },
        "metadata": {
          "type": "object",
          "description": "Arbitrary key-value metadata for renderer extensions",
          "additionalProperties": true
        },
        "children": {
          "type": "array",
          "description": "Nested sub-nodes for drill-down views",
          "items": { "$ref": "#/definitions/DiagramNode" },
          "default": []
        }
      }
    },
    "DiagramEdge": {
      "type": "object",
      "description": "A directed connection between two nodes",
      "required": ["id", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique semantic ID for this edge in kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$"
        },
        "from": {
          "type": "string",
          "description": "ID of the source node"
        },
        "to": {
          "type": "string",
          "description": "ID of the target node"
        },
        "label": {
          "type": "string",
          "description": "What this connection represents (e.g. 'queries', 'publishes to', 'HTTP GET')"
        },
        "complexity": {
          "$ref": "#/definitions/ComplexityLevel",
          "default": "low"
        },
        "style": {
          "$ref": "#/definitions/EdgeStyle",
          "default": "solid"
        },
        "direction": {
          "$ref": "#/definitions/EdgeDirection",
          "default": "forward"
        }
      }
    },
    "DiagramGroup": {
      "type": "object",
      "description": "A logical grouping of nodes (VPC, region, team, domain boundary)",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique semantic ID in kebab-case",
          "pattern": "^[a-z0-9]+(-[a-z0-9.]+)*$"
        },
        "label": {
          "type": "string",
          "description": "Display name for the group",
          "minLength": 1
        },
        "complexity": {
          "$ref": "#/definitions/ComplexityLevel",
          "default": "medium"
        },
        "contains": {
          "type": "array",
          "description": "List of node IDs that belong to this group",
          "items": { "type": "string" },
          "default": []
        },
        "metadata": {
          "type": "object",
          "description": "Arbitrary metadata (e.g. region name, CIDR block)",
          "additionalProperties": true
        }
      }
    }
  }
}
