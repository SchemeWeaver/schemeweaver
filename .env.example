# API keys — add a key to enable that provider.
# The first provider with an accessible model (in registry order) is used by default.
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=

# Ollama base URL — override if running on a remote host (no /v1 suffix)
# OLLAMA_BASE_URL=http://localhost:11434

REDIS_URL=redis://localhost:6379
USE_ASYNC_WORKER=false
